APP_NAME=Campus AIGC Virtual Tour API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# OpenAI-compatible API (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Chat channel (preferred, fallback to OPENAI_* if empty)
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=

# ASR channel (preferred, fallback to OPENAI_* if empty)
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=

# Speech engine switch (mock|none)
TTS_ENGINE=mock

# ASR engine switch (mock|openai)
ASR_ENGINE=mock

# Example for DeepSeek chat + separate ASR provider:
# CHAT_API_KEY=sk-xxx
# CHAT_BASE_URL=https://api.deepseek.com/v1
# CHAT_MODEL=deepseek-chat
# ASR_ENGINE=openai
# ASR_API_KEY=sk-xxx
# ASR_BASE_URL=https://api.openai.com/v1
# ASR_MODEL=whisper-1
